# ---------------------------------------------------------------------------
# MajsterAI Dashboard — environment configuration
# Copy to .env and fill in real values. Never commit .env to git.
# All variables prefixed with VITE_ are exposed to the browser bundle.
# ---------------------------------------------------------------------------

# Base URL of the FastAPI backend.
# For local development the Vite dev server proxies /api → localhost:8000
# so this can be left blank. Set it explicitly for staging/production builds.
VITE_API_BASE_URL=http://localhost:8000

# LiveKit Cloud URL (required for the in-browser test-agent widget)
# VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
