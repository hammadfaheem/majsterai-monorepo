# ---------------------------------------------------------------------------
# MajsterAI API — environment configuration
# Copy to .env and fill in real values. Never commit .env to git.
# ---------------------------------------------------------------------------

# Application
ENVIRONMENT=development
# Set to true ONLY for local development — NEVER in production
DEBUG=true
# Public-facing API URL used for Twilio webhook callbacks
BASE_URL=https://your-api.example.com

# Auth — REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-secure-random-32-plus-character-secret
JWT_EXPIRATION_HOURS=24

# Database (Neon PostgreSQL or local)
DATABASE_URL=postgresql://majsterai:your_password_here@localhost:5432/majsterai
# For Neon: DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# CORS — comma-separated list of allowed origins (production)
# CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
LIVEKIT_SIP_DOMAIN=sip.livekit.cloud

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Google Calendar OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Platform superadmin (optional — grants SUPERADMIN role on startup)
# SUPERADMIN_EMAIL=admin@example.com
